APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Provider Configuration
# -------------------------

# Default providers (local-ai, lmstudio, openai)
AI_EMBEDDING_PROVIDER=local-ai
AI_LLM_PROVIDER=local-ai

# local-ai Settings (Default)
# ---------------------------
LOCALAI_URL=http://localhost:8080
LOCALAI_API_KEY=
LOCALAI_EMBEDDING_MODEL=nomic-embed-text-v1.5
LOCALAI_EMBEDDING_DIMENSIONS=768
LOCALAI_LLM_MODEL=Qwen3.5-9B-GGUF
LOCALAI_TIMEOUT=60
LOCALAI_TEMPERATURE=0.7
LOCALAI_MAX_TOKENS=1024

# LMStudio Settings (Legacy)
# --------------------------
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_API_KEY=lmstudio
# LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v2
# LMSTUDIO_EMBEDDING_DIMENSIONS=768
# LMSTUDIO_TIMEOUT=60

# OpenAI Settings (Future External Provider)
# ------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=30

# AI Retry Configuration
# ----------------------
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_BASE_DELAY_MS=1000

# AI Feature Flags
# ----------------
AI_ENABLE_HYPOTHETICAL_QUESTIONS=true
AI_QUESTIONS_PER_CHUNK=4
AI_EMBEDDING_CACHE=false
AI_LLM_CACHE=false
AI_EMBEDDING_CACHE_TTL=86400
AI_LLM_CACHE_TTL=86400

# AI Hybrid Search
# ----------------
AI_SEARCH_VECTOR_WEIGHT=0.6
AI_SEARCH_KEYWORD_WEIGHT=0.3
AI_SEARCH_QUESTION_WEIGHT=0.1
AI_SEARCH_ENABLE_RERANKING=true

# AI Search Validation
# --------------------
AI_VALIDATION_ENABLED=true
AI_VALIDATION_NODES=gatekeeper,auditor,strategist
AI_VALIDATION_FAIL_ACTION=fallback  # fallback, retry, or reject
