{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "handoff": {
            "type": "local",
            "enabled": true,
            "command": [
                "python",
                ".opencode/scripts/mcp_wrapper.py"
            ],
            "environment": {}
        }
    }
}
